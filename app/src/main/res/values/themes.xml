<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DadasChatPos" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/dark_red</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/surface_soft</item>
        <item name="colorOnPrimaryContainer">@color/dark_red</item>
        <item name="colorSecondary">@color/gold</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/white</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:editTextColor">@color/text_primary</item>
        <item name="textInputStyle">@style/Widget.Dadas.TextInputLayout</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/dark_red</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="fontFamily">sans</item>
        <item name="materialButtonStyle">@style/Widget.Dadas.Button</item>
    </style>

    <style name="Widget.Dadas.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Dadas.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/white</item>
        <item name="boxStrokeColor">@color/text_input_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/text_input_hint</item>
        <item name="endIconTint">@color/text_input_hint</item>
    </style>

    <style name="DadasFoodImageShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Widget.Dadas.IconButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">0dp</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="Widget.Dadas.IconButton.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">0dp</item>
        <item name="cornerRadius">14dp</item>
    </style>
</resources>
